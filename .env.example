# ==============================================================================
# Local Development Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# These mirror the GitHub Environment vars/secrets used in CI.
# The CDK app loads them via dotenv at synth time.
# .env is gitignored — never commit secrets to source control.
# ==============================================================================

# ── AWS Account & Region ─────────────────────────────────────────────────────
# Single source of truth for the AWS account ID targeted by CDK synth.
#
# CI:    set per GH Environment via vars.AWS_ACCOUNT_ID; the workflow
#        exports it into process.env before invoking cdk.
# Local: set here for the env you're synthing against (development by default).
#
# Required — synth fails loud if missing. See:
#   docs/superpowers/specs/2026-05-05-eks-migration-design.md § 9.1
AWS_ACCOUNT_ID=

# ROOT_ACCOUNT is the org root account, used by cross-account DNS validation
# and other shared-org constructs. Required only when synthing the `org`
# project or the management environment.
ROOT_ACCOUNT=

# ── Edge / CloudFront Configuration ──────────────────────────────────────────
# Required for the Edge stack (us-east-1). Without these, synth produces errors.
DOMAIN_NAME=dev.nelsonlamounier.com
HOSTED_ZONE_ID=
CROSS_ACCOUNT_ROLE_ARN=

# ── WAF IP Allowlist (Pre-launch Access Restriction) ─────────────────────────
# Controls CloudFront IP allowlist for pre-launch access restriction.
#
# To restrict access:  set RESTRICT_ACCESS=true and provide your IPs
# To go live:          set RESTRICT_ACCESS=false (or remove these lines)
#
# Find your IPs: curl -4 -s ifconfig.me (IPv4) / curl -s ifconfig.me (IPv6)
RESTRICT_ACCESS=true
ALLOW_IPV4=
ALLOW_IPV6=

# ── Email / API Configuration ────────────────────────────────────────────────
NOTIFICATION_EMAIL=
SES_FROM_EMAIL=
VERIFICATION_SECRET=
VERIFICATION_BASE_URL=
