# admin-api local development environment
#
# Copy to .env and fill in values for local testing.
# NEVER commit .env — it is gitignored.
#
# In Kubernetes:
#   Secrets  → admin-api-secrets  (K8s Secret   — managed by deploy.py)
#   Config   → admin-api-config   (K8s ConfigMap — managed by deploy.py)
#   AWS creds → EC2 Instance Profile via IMDS (no credential env vars needed)

# ── K8s Secret: admin-api-secrets ────────────────────────────────────────────
# (Cognito auth creds — sensitive, encrypted at rest in K8s etcd)
COGNITO_USER_POOL_ID=eu-west-1_XXXXXXXXX
COGNITO_CLIENT_ID=your-cognito-client-id
COGNITO_ISSUER_URL=https://cognito-idp.eu-west-1.amazonaws.com/eu-west-1_XXXXXXXXX

# ── K8s ConfigMap: admin-api-config ──────────────────────────────────────────
# (Non-sensitive infrastructure references — plain text in ConfigMap)
DYNAMODB_TABLE_NAME=bedrock-dev-ai-content
DYNAMODB_GSI1_NAME=gsi1-status-date
DYNAMODB_GSI2_NAME=gsi2-tag-date

ASSETS_BUCKET_NAME=bedrock-dev-kb-data

PUBLISH_LAMBDA_ARN=arn:aws:lambda:eu-west-1:771826808455:function:bedrock-dev-pipeline-publish
ARTICLE_TRIGGER_ARN=arn:aws:lambda:eu-west-1:771826808455:function:bedrock-dev-pipeline-trigger
VERSION_HISTORY_LAMBDA_ARN=arn:aws:lambda:eu-west-1:771826808455:function:bedrock-dev-pipeline-version-history
STRATEGIST_TRIGGER_ARN=arn:aws:lambda:eu-west-1:771826808455:function:bedrock-dev-strategist-trigger
STRATEGIST_TABLE_NAME=bedrock-dev-strategist

AWS_DEFAULT_REGION=eu-west-1

# ── K8s Secret: admin-api-github ─────────────────────────────────────────────
# (GitHub App credentials — optional; GitHub routes return 503 when absent)
# Source:  github.com/settings/apps → App ID + generate a private key (PEM)
# Cluster: Secrets Manager secret k8s/development/tucaken-github-app
#          (keys: github_app_id, github_app_private_key) + SSM SecureString
#          /k8s/development/tucaken-webhook-secret → synced by ESO → admin-api-github Secret
# Local:   set directly below; run "just github-app-secrets" to push to AWS
#
# GITHUB_APP_ID=123456
# GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ── Local dev only ────────────────────────────────────────────────────────────
PORT=3002

# ── AWS credentials (local dev only) ─────────────────────────────────────────
# In production: NOT SET — credentials come from EC2 Instance Profile (IMDS).
# Locally: the docker-compose.yml mounts ~/.aws read-only and passes AWS_PROFILE.
# Set this to the AWS profile name that has lambda:InvokeFunction, s3:PutObject,
# and dynamodb:* permissions on bedrock-dev resources.
# AWS_PROFILE=dev-account
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
