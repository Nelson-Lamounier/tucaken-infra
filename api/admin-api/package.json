{
  "name": "@repo/admin-api",
  "version": "0.1.0",
  "private": true,
  "description": "admin-api — BFF (Backend for Frontend) for the start-admin TanStack application. Provides write-heavy REST endpoints protected by Cognito JWT bearer authentication via JWKS validation.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.0.0",
    "@aws-sdk/client-cost-explorer": "^3.0.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@hono/node-server": "^1.13.7",
    "@kubernetes/client-node": "^1.4.0",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1039.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
