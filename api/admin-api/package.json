{
  "name": "@repo/admin-api",
  "version": "0.1.0",
  "private": true,
  "description": "admin-api — BFF (Backend for Frontend) for the tucaken-app TanStack application. Provides write-heavy REST endpoints protected by Cognito JWT bearer authentication via JWKS validation.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --import ./src/lib/observability/telemetry.ts src/index.ts",
    "start": "node --import ./dist/lib/observability/telemetry.js dist/index.js",
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.0.0",
    "@aws-sdk/client-cost-explorer": "^3.0.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@hono/node-server": "^1.13.7",
    "@kubernetes/client-node": "^1.4.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.53.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/resources": "^1.28.0",
    "@opentelemetry/sdk-node": "^0.55.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@pyroscope/nodejs": "^0.4.5",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "pg": "^8.20.0",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1039.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
