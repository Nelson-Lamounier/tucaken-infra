        <!-- Legend -->
        <mxCell id="legend-bg" style="verticalLabelPosition=bottom;verticalAlign=top;html=1;shape=mxgraph.basic.rect;fillColor2=none;strokeWidth=1;size=20;indent=5;fillColor=light-dark(#EDF3FF,#305363);strokeColor=#6c8ebf;fontFamily=Helvetica;" value="" vertex="1" parent="1">
          <mxGeometry height="700" width="560" x="1120" y="150" as="geometry" />
        </mxCell>
        <mxCell id="legend-title" value="Connection path" style="text;html=1;align=left;verticalAlign=top;fontSize=18;fontStyle=1;fontFamily=Helvetica;fontColor=light-dark(#232F3E,#FFFFFF);" vertex="1" parent="1">
          <mxGeometry x="1150" y="170" width="500" height="30" as="geometry" />
        </mxCell>
        <mxCell id="legend-steps" value="&lt;b&gt;1 &#183; App pod &#8594; PgBouncer&lt;/b&gt;&#160; pg Pool (max 5 client conns), transaction-scoped.&lt;br&gt;&lt;br&gt;&lt;b&gt;2 &#183; PgBouncer &#8594; RDS&lt;/b&gt;&#160; TCP 5432 over TLS, &#8804;20 pooled server connections, VPC-internal via the local route.&lt;br&gt;&lt;br&gt;&lt;b&gt;3 &#183; SG-to-SG ingress&lt;/b&gt;&#160; EksClusterStack grants the RDS SG inbound 5432 from the EKS cluster SG. This replaces the removed VPC-CIDR rule; no CIDR ingress remains.&lt;br&gt;&lt;br&gt;&lt;b&gt;4 &#183; SSM &#8594; ESO&lt;/b&gt;&#160; host / port / secret-arn published by CDK; RDS reads the VPC + isolated subnet IDs from SSM at deploy time.&lt;br&gt;&lt;br&gt;&lt;b&gt;5 &#183; Secrets Manager &#8594; ESO&lt;/b&gt;&#160; auto-generated master credentials.&lt;br&gt;&lt;br&gt;&lt;b&gt;6 &#183; ESO &#8594; PgBouncer&lt;/b&gt;&#160; synced Kubernetes Secret injects PG_HOST + credentials at pod start." style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontFamily=Helvetica;fontColor=light-dark(#232F3E,#F5F5F5);whiteSpace=wrap;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="1150" y="210" width="510" height="470" as="geometry" />
        </mxCell>
        <mxCell id="legend-note" value="&lt;b&gt;Isolated subnet = private, zero NAT.&lt;/b&gt;&lt;br&gt;RDS needs no outbound internet; backups, metrics and Performance Insights ride the AWS backbone. The subnet route table is local-only (10.0.0.0/16), so there is no IGW or NAT Gateway cost (~$35/mo avoided)." style="text;html=1;align=left;verticalAlign=top;fontSize=13;fontFamily=Helvetica;fontColor=light-dark(#232F3E,#F5F5F5);whiteSpace=wrap;spacingLeft=4;labelBackgroundColor=none;" vertex="1" parent="1">
          <mxGeometry x="1150" y="700" width="510" height="130" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
