{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CoreInfrastructureServices",
      "Effect": "Allow",
      "Action": [
        "cloudformation:*",
        "ecs:*",
        "ec2:*",
        "elasticfilesystem:*",
        "elasticloadbalancing:*",
        "autoscaling:*",
        "application-autoscaling:*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "MonitoringAndLogging",
      "Effect": "Allow",
      "Action": ["logs:*", "cloudwatch:*"],
      "Resource": "*"
    },
    {
      "Sid": "IAMManagement",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:GetRole",
        "iam:PassRole",
        "iam:TagRole",
        "iam:UntagRole",
        "iam:UpdateRole",
        "iam:UpdateRoleDescription",
        "iam:UpdateAssumeRolePolicy",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:PutRolePolicy",
        "iam:GetRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:ListRolePolicies",
        "iam:ListAttachedRolePolicies",
        "iam:CreatePolicy",
        "iam:DeletePolicy",
        "iam:GetPolicy",
        "iam:CreatePolicyVersion",
        "iam:DeletePolicyVersion",
        "iam:ListPolicyVersions",
        "iam:CreateServiceLinkedRole",
        "iam:DeleteServiceLinkedRole",
        "iam:GetServiceLinkedRoleDeletionStatus",
        "iam:CreateInstanceProfile",
        "iam:DeleteInstanceProfile",
        "iam:AddRoleToInstanceProfile",
        "iam:RemoveRoleFromInstanceProfile",
        "iam:GetInstanceProfile",
        "iam:ListInstanceProfilesForRole",
        "iam:ListInstanceProfiles",
        "iam:CreateUser",
        "iam:DeleteUser",
        "iam:GetUser",
        "iam:TagUser",
        "iam:UntagUser",
        "iam:UpdateUser",
        "iam:ListAccessKeys",
        "iam:CreateAccessKey",
        "iam:DeleteAccessKey",
        "iam:PutUserPolicy",
        "iam:GetUserPolicy",
        "iam:DeleteUserPolicy",
        "iam:ListUserPolicies",
        "iam:AttachUserPolicy",
        "iam:DetachUserPolicy",
        "iam:ListAttachedUserPolicies",
        "iam:ListGroupsForUser"
      ],
      "Resource": "*"
    },
    {
      "Sid": "SSMFullAccess",
      "Effect": "Allow",
      "Action": "ssm:*",
      "Resource": "*"
    },
    {
      "Sid": "ContainerServices",
      "Effect": "Allow",
      "Action": ["ecr:*", "lambda:*"],
      "Resource": "*"
    },
    {
      "Sid": "StorageServices",
      "Effect": "Allow",
      "Action": "s3:*",
      "Resource": "*"
    },
    {
      "Sid": "SecretsAndEncryption",
      "Effect": "Allow",
      "Action": ["secretsmanager:*", "kms:*"],
      "Resource": "*"
    },
    {
      "Sid": "EventsAndMessaging",
      "Effect": "Allow",
      "Action": ["events:*", "sns:*", "sqs:*"],
      "Resource": "*"
    },
    {
      "Sid": "NetworkingServices",
      "Effect": "Allow",
      "Action": ["servicediscovery:*", "route53:*"],
      "Resource": "*"
    },
    {
      "Sid": "CertificateManagement",
      "Effect": "Allow",
      "Action": "acm:*",
      "Resource": "*"
    },
    {
      "Sid": "DynamoDBManagement",
      "Effect": "Allow",
      "Action": "dynamodb:*",
      "Resource": "*"
    },
    {
      "Sid": "ApiGatewayManagement",
      "Effect": "Allow",
      "Action": "apigateway:*",
      "Resource": "*"
    },
    {
      "Sid": "DataLifecycleManager",
      "Effect": "Allow",
      "Action": "dlm:*",
      "Resource": "*"
    },
    {
      "Sid": "ImageBuilderServices",
      "Effect": "Allow",
      "Action": "imagebuilder:*",
      "Resource": "*"
    },
    {
      "Sid": "WebApplicationFirewall",
      "Effect": "Allow",
      "Action": "wafv2:*",
      "Resource": "*"
    },
    {
      "Sid": "EmailServices",
      "Effect": "Allow",
      "Action": "ses:*",
      "Resource": "*"
    },
    {
      "Sid": "ContentDeliveryNetwork",
      "Effect": "Allow",
      "Action": "cloudfront:*",
      "Resource": "*"
    },
    {
      "Sid": "BedrockAIServices",
      "Effect": "Allow",
      "Action": ["bedrock:*", "bedrock-agentcore:*", "aoss:*"],
      "Resource": "*"
    },
    {
      "Sid": "CognitoIdentityServices",
      "Effect": "Allow",
      "Action": ["cognito-idp:*", "cognito-identity:*"],
      "Resource": "*"
    },
    {
      "Sid": "StepFunctionsOrchestration",
      "Effect": "Allow",
      "Action": "states:*",
      "Resource": "*"
    },
    {
      "Sid": "SecurityServices",
      "Effect": "Allow",
      "Action": ["guardduty:*", "securityhub:*", "access-analyzer:*", "cloudtrail:*"],
      "Resource": "*"
    },
    {
      "Sid": "RelationalDatabaseServices",
      "Effect": "Allow",
      "Action": "rds:*",
      "Resource": "*"
    },
    {
      "Sid": "EksClusterAndNodegroups",
      "Effect": "Allow",
      "Action": ["eks:*"],
      "Resource": "*"
    },
    {
      "Sid": "PricingForKarpenter",
      "Effect": "Allow",
      "Action": ["pricing:GetProducts"],
      "Resource": "*"
    },
    {
      "Sid": "FinOpsServices",
      "Effect": "Allow",
      "Action": "budgets:*",
      "Resource": "*"
    },
    {
      "Sid": "STSAccess",
      "Effect": "Allow",
      "Action": ["sts:AssumeRole", "sts:GetCallerIdentity"],
      "Resource": "*"
    }
  ]
}
